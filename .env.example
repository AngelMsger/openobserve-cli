# openobserve-cli environment configuration
# Copy to .env and fill in. All variables are optional and overridable by CLI flags.

# OpenObserve server URL (self-hosted: http://localhost:5080, Cloud: https://api.openobserve.ai)
OPENOBSERVE_URL=http://localhost:5080

# Organization identifier (default: default)
OPENOBSERVE_ORG=default

# --- Authentication: pick ONE scheme ---

# Basic auth: email + password (for SSO instances, use a Service Account's email + token)
OPENOBSERVE_EMAIL=
OPENOBSERVE_PASSWORD=

# Token auth: a pre-generated credential (base64 of email:token, or a full Basic/Bearer value)
OPENOBSERVE_TOKEN=

# Default output format: json | table | ndjson
OPENOBSERVE_FORMAT=json

# Session read-only posture (1 to block writes before they leave the CLI)
OPENOBSERVE_CLI_READ_ONLY=
